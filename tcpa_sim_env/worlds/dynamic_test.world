<?xml version="1.0"?>
<sdf version="1.6">
  <world name="dynamic_test">
    <gravity>0 0 -9.8</gravity>
    <magnetic_field>6e-06 2.3e-05 -4.2e-05</magnetic_field>
    <atmosphere type="adiabatic"/>

    <physics name="default_physics" type="ode">
      <max_step_size>0.001</max_step_size>
      <real_time_factor>1.0</real_time_factor>
      <real_time_update_rate>1000</real_time_update_rate>
    </physics>

    <scene>
      <ambient>0.45 0.45 0.45 1.0</ambient>
      <background>0.75 0.82 0.88 1.0</background>
      <shadows>false</shadows>
    </scene>

    <include>
      <uri>model://ground_plane</uri>
    </include>

    <include>
      <uri>model://sun</uri>
    </include>

    <model name="arena_floor">
      <static>true</static>
      <pose>0 0 0 0 0 0</pose>
      <link name="floor_link">
        <collision name="floor_collision">
          <geometry>
            <box>
              <size>10 10 0.02</size>
            </box>
          </geometry>
        </collision>
        <visual name="floor_visual">
          <geometry>
            <box>
              <size>10 10 0.02</size>
            </box>
          </geometry>
          <material>
            <ambient>0.88 0.88 0.88 1.0</ambient>
            <diffuse>0.88 0.88 0.88 1.0</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <model name="north_wall">
      <static>true</static>
      <pose>0 5 0.25 0 0 0</pose>
      <link name="wall_link">
        <collision name="collision">
          <geometry>
            <box>
              <size>10 0.15 0.5</size>
            </box>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <box>
              <size>10 0.15 0.5</size>
            </box>
          </geometry>
          <material>
            <ambient>0.55 0.55 0.60 1.0</ambient>
            <diffuse>0.55 0.55 0.60 1.0</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <model name="south_wall">
      <static>true</static>
      <pose>0 -5 0.25 0 0 0</pose>
      <link name="wall_link">
        <collision name="collision">
          <geometry>
            <box>
              <size>10 0.15 0.5</size>
            </box>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <box>
              <size>10 0.15 0.5</size>
            </box>
          </geometry>
          <material>
            <ambient>0.55 0.55 0.60 1.0</ambient>
            <diffuse>0.55 0.55 0.60 1.0</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <model name="east_wall">
      <static>true</static>
      <pose>5 0 0.25 0 0 0</pose>
      <link name="wall_link">
        <collision name="collision">
          <geometry>
            <box>
              <size>0.15 10 0.5</size>
            </box>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <box>
              <size>0.15 10 0.5</size>
            </box>
          </geometry>
          <material>
            <ambient>0.55 0.55 0.60 1.0</ambient>
            <diffuse>0.55 0.55 0.60 1.0</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <model name="west_wall">
      <static>true</static>
      <pose>-5 0 0.25 0 0 0</pose>
      <link name="wall_link">
        <collision name="collision">
          <geometry>
            <box>
              <size>0.15 10 0.5</size>
            </box>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <box>
              <size>0.15 10 0.5</size>
            </box>
          </geometry>
          <material>
            <ambient>0.55 0.55 0.60 1.0</ambient>
            <diffuse>0.55 0.55 0.60 1.0</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <model name="static_cylinder_1">
      <static>true</static>
      <pose>-0.5 2.0 0.45 0 0 0</pose>
      <link name="obstacle_link">
        <collision name="collision">
          <geometry>
            <cylinder>
              <radius>0.32</radius>
              <length>0.9</length>
            </cylinder>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <cylinder>
              <radius>0.32</radius>
              <length>0.9</length>
            </cylinder>
          </geometry>
          <material>
            <ambient>0.15 0.60 0.25 1.0</ambient>
            <diffuse>0.15 0.60 0.25 1.0</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <model name="static_cylinder_2">
      <static>true</static>
      <pose>2.2 -1.8 0.45 0 0 0</pose>
      <link name="obstacle_link">
        <collision name="collision">
          <geometry>
            <cylinder>
              <radius>0.28</radius>
              <length>0.9</length>
            </cylinder>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <cylinder>
              <radius>0.28</radius>
              <length>0.9</length>
            </cylinder>
          </geometry>
          <material>
            <ambient>0.72 0.42 0.16 1.0</ambient>
            <diffuse>0.72 0.42 0.16 1.0</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <actor name="crossing_actor">
      <pose>-1.0 -3.0 0.55 0 0 0</pose>
      <link name="body_link">
        <inertial>
          <mass>8.0</mass>
          <inertia>
            <ixx>0.2</ixx>
            <ixy>0.0</ixy>
            <ixz>0.0</ixz>
            <iyy>0.2</iyy>
            <iyz>0.0</iyz>
            <izz>0.1</izz>
          </inertia>
        </inertial>
        <collision name="collision">
          <geometry>
            <box>
              <size>0.5 0.5 1.1</size>
            </box>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <box>
              <size>0.5 0.5 1.1</size>
            </box>
          </geometry>
          <material>
            <ambient>0.88 0.20 0.20 1.0</ambient>
            <diffuse>0.88 0.20 0.20 1.0</diffuse>
          </material>
        </visual>
      </link>
      <script>
        <loop>true</loop>
        <auto_start>true</auto_start>
        <trajectory id="0" type="crossing">
          <waypoint>
            <time>0.0</time>
            <pose>-1.0 -3.0 0.55 0 0 0</pose>
          </waypoint>
          <waypoint>
            <time>5.0</time>
            <pose>-1.0 3.0 0.55 0 0 0</pose>
          </waypoint>
          <waypoint>
            <time>10.0</time>
            <pose>-1.0 -3.0 0.55 0 0 0</pose>
          </waypoint>
        </trajectory>
      </script>
    </actor>

    <actor name="headon_actor">
      <pose>4.0 0.0 0.55 0 0 0</pose>
      <link name="body_link">
        <inertial>
          <mass>8.0</mass>
          <inertia>
            <ixx>0.2</ixx>
            <ixy>0.0</ixy>
            <ixz>0.0</ixz>
            <iyy>0.2</iyy>
            <iyz>0.0</iyz>
            <izz>0.1</izz>
          </inertia>
        </inertial>
        <collision name="collision">
          <geometry>
            <cylinder>
              <radius>0.28</radius>
              <length>1.1</length>
            </cylinder>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <cylinder>
              <radius>0.28</radius>
              <length>1.1</length>
            </cylinder>
          </geometry>
          <material>
            <ambient>0.18 0.22 0.85 1.0</ambient>
            <diffuse>0.18 0.22 0.85 1.0</diffuse>
          </material>
        </visual>
      </link>
      <script>
        <loop>true</loop>
        <auto_start>true</auto_start>
        <trajectory id="0" type="head_on">
          <waypoint>
            <time>0.0</time>
            <pose>4.0 0.0 0.55 0 0 0</pose>
          </waypoint>
          <waypoint>
            <time>8.0</time>
            <pose>-4.0 0.0 0.55 0 0 0</pose>
          </waypoint>
          <waypoint>
            <time>16.0</time>
            <pose>4.0 0.0 0.55 0 0 0</pose>
          </waypoint>
        </trajectory>
      </script>
    </actor>
  </world>
</sdf>
